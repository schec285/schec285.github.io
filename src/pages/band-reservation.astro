---
import PrLayout from "../layouts/ProjectLayout.astro";
import TechStackSection from "../components/TechStackSection.astro";

const tech = [
    "TypeScript",
    "Next.js",
    "React",
    "PostgreSQL",
];
---

<PrLayout
    title="バンド予約サイトの紹介"
    thumbnail="/band-reservation_thumbnail.png"
>
    <section class="mt-6 space-y-6">
        <div>
            <h2 class="text-2xl font-bold">概要</h2>
            <p class="mt-2 leading-7 text-slate-700 dark:text-slate-300">
                バンドのライブ予約を管理するためのサイトです。
                ユーザーはライブの予約を行い、管理者はイベント管理ができます。
            </p>
        </div>

        <div>
            <h2 class="text-2xl font-bold">テスト環境</h2>
            <a
                href="https://band-session.vercel.app/"
                target="_blank"
                class="mt-2 leading-7 text-slate-700 dark:text-slate-300 underline"
            >
                https://band-session.vercel.app/
            </a>
            <div
                class="rounded-md border border-slate-200 bg-slate-50 p-4 text-sm dark:border-slate-700 dark:bg-slate-900"
            >
                <p class="font-semibold text-slate-900 dark:text-slate-100">
                    テスト用アカウント
                </p>
                <dl class="mt-2 grid gap-1 text-slate-700 dark:text-slate-300">
                    <div class="flex gap-2">
                        <dt class="w-24 shrink-0 font-medium">一般ユーザ</dt>
                        <dd>test@example.com / Password1@</dd>
                    </div>
                    <div class="flex gap-2">
                        <dt class="w-24 shrink-0 font-medium">管理者</dt>
                        <dd>admin@example.com / Password1@</dd>
                    </div>
                </dl>
            </div>
        </div>

        <div>
            <h2 class="text-2xl font-bold">主な機能</h2>
            <ul
                class="mt-2 list-disc space-y-1 pl-5 text-slate-700 dark:text-slate-300"
            >
                <li>ユーザー登録とログイン</li>
                <li>予約機能</li>
                <li>メール機能</li>
                <li>管理者画面</li>
            </ul>
        </div>

        <div>
            <h2 class="text-2xl font-bold">技術スタック</h2>
            <TechStackSection tech={tech} />
        </div>

        <div>
            <h2 class="text-2xl font-bold">学んだこと</h2>
            <p class="mt-2 leading-7 text-slate-700 dark:text-slate-300">
                バンド予約サイトの開発を通じて、Next.jsでのフルスタック開発の基礎を学びました。
                フロントエンドではReactを使用し、バックエンドではAPI Routesで実装しました。
            </p>
            <p class="mt-2 leading-7 text-slate-700 dark:text-slate-300">
                Neonを使用する為PostgreSQLを使用し、ORMはdrizzleを利用しました。
            </p>
            <p class="mt-2 leading-7 text-slate-700 dark:text-slate-300">
                バンド活動を個人活動しているので、実際にシステムを運用することを想定しつつ、モダンな技術を学ぶことも目的として開発を行いました。
            </p>
            <p class="mt-2 leading-7 text-slate-700 dark:text-slate-300">
                Vercel,Neon,Resend,GitHub等外部サービスを利用することで効率よく開発に集中しながら、スピード感のある開発フローの構築と手法を学ぶことができました。
            </p>
        </div>
    </section>
</PrLayout>
