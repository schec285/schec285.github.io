---
import Layout from "../layouts/Layout.astro";
import { Icon } from "astro-icon/components";

interface Props {
    title?: string;
    thumbnail: string;
}
const { title, thumbnail } = Astro.props;
---

<Layout title={title}>
    <h1 class="text-4xl font-bold">
        {title}
    </h1>
    <div class="my-3">
        <a
            href="/"
            class="text-sm text-slate-600 dark:text-slate-400 hover:underline"
        >
            <div class="flex items-center gap-1">
                <Icon name="ooui:next-rtl" />ホーム
            </div>
        </a>
    </div>
    <main
        class="min-h-screen px-5 py-4 rounded-md
        bg-slate-50 text-slate-900
        dark:bg-slate-950 dark:text-slate-100"
    >
        <a
            href={thumbnail}
            data-pswp-width="1200"
            data-pswp-height="800"
            target="_blank"
        >
            <img src={thumbnail} alt={title} class="mb-4 w-full rounded-lg" />
        </a>
        <slot />
    </main>
</Layout>
