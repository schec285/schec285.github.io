---
import Layout from "../layouts/Layout.astro";

interface Props {
title?: string;
}

const { title } = Astro.props;
---

<Layout title={title}>
    <h1 class="text-4xl font-bold">
        {title}
    </h1>
    <div class="my-3">
        <a href="/" class="text-sm text-slate-600 dark:text-slate-400 hover:underline">
            &lt; ホーム
        </a>
    </div>
    <main
    class="
        min-h-screen px-5 py-1
        bg-slate-50 text-slate-900
        dark:bg-slate-950 dark:text-slate-100
    "
    >
        <slot />
    </main>
</Layout>