---
import { Icon } from "astro-icon/components";

interface Props {
  title: string;
  tech: string;
  link?: string;
}

const { title, tech, link } = Astro.props;
---

<a
  href={link}
  class="block rounded-xl border p-6 transition
    bg-white text-slate-900 border-slate-200
    dark:bg-slate-900 dark:text-slate-100 dark:border-slate-700
    hover:border-slate-300 hover:shadow-sm dark:hover:border-slate-600"
>
  <div class="flex items-center justify-between gap-4">
    <div>
      <h3 class="text-lg font-bold">
        {title}
      </h3>

      <p class="mt-3 text-sm text-slate-600 dark:text-slate-400">
        {tech}
      </p>
    </div>
    <div class="text-xl text-slate-400 dark:text-slate-500" aria-hidden="true">
      <Icon name="ooui:next-ltr" />
    </div>
  </div>
</a>
